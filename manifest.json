{
  "manifest_version": 3,
  "name": "Jails Component Inspector",
  "version": "0.1.0",
  "description": "Inspect and visualize Jails components as an interactive graph",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest"
  ],
  "icons": {
	"16": "logo16.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jails Inspector"
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
